# ============== LLM API configuration ==============
# Any OpenAI-SDK-compatible provider (OpenAI, Azure OpenAI, Qwen, etc.)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# ============== Graphiti / Neo4j backend ==============
# Points at the Neo4j service.
#   - Local docker-compose: bolt://neo4j:7687
#   - Railway (two-service project): bolt://neo4j.railway.internal:7687
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish-local-password

# ============== Language override ==============
# Forces the backend to respond in English regardless of browser Accept-Language.
# Unset to restore per-request locale detection.
APP_LOCALE=en

# ============== Simulation knobs (optional) ==============
OASIS_DEFAULT_MAX_ROUNDS=3
REPORT_AGENT_MAX_TOOL_CALLS=2
REPORT_AGENT_MAX_REFLECTION_ROUNDS=1
